{
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:event:default",
		"opener:default",
		"deep-link:default",
		"http:default",
		{
			"identifier": "http:allow-fetch",
			"allow": [{ "url": "https://*/*" }, { "url": "http://*/*" }]
		},
		"cors-fetch:default",
		"oauth:allow-start",
		"oauth:allow-cancel",
		"clipboard-manager:allow-write-text",
		"updater:default",
		"process:allow-restart"
	]
}
