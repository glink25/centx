{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "cent",
	"version": "0.1.0",
	"identifier": "com.glink.dailycent",
	"build": {
		"beforeDevCommand": "TAURI_VITE=1 pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "TAURI_VITE=1 pnpm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "cent",
				"width": 800,
				"height": 600
			}
		],
		"security": {
			"csp": "default-src 'self' tauri: http: https: 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' http: https:;"
		},
		"withGlobalTauri": true
	},
	"plugins": {
		"deep-link": {
			"mobile": [
				{
					"scheme": ["dailycent"],
					"appLink": false
				}
			],
			"desktop": {
				"schemes": ["dailycent"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"android": {
			"minSdkVersion": 24,
			"autoIncrementVersionCode": false
		},
		"linux": {
			"appimage": {
				"bundleMediaFramework": false,
				"files": {}
			},
			"deb": {
				"files": {}
			},
			"rpm": {
				"epoch": 0,
				"files": {},
				"release": "1"
			}
		},
		"macOS": {
			"dmg": {
				"appPosition": {
					"x": 180,
					"y": 170
				},
				"applicationFolderPosition": {
					"x": 480,
					"y": 170
				},
				"windowSize": {
					"height": 400,
					"width": 660
				}
			},
			"files": {},
			"hardenedRuntime": true,
			"minimumSystemVersion": "10.13"
		},
		"windows": {
			"allowDowngrades": true,
			"tsp": false,
			"webviewInstallMode": {
				"silent": true,
				"type": "downloadBootstrapper"
			}
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico",
			"icons/icon.png",
			"icons/ios/*.png",
			"icons/android"
		]
	}
}
