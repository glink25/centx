{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "cent",
	"version": "0.1.0",
	"identifier": "com.glink.dailycent",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "cent",
				"width": 800,
				"height": 600,
				"url": "centapp://localhost/"
			}
		],
		"security": {
			"csp": "default-src 'self' centapp: tauri: http: https: data: blob: 'unsafe-inline'; script-src 'self' centapp: 'wasm-unsafe-eval'; connect-src 'self' centapp: http: https: ipc: http://ipc.localhost; img-src 'self' centapp: http: https: data: blob:; font-src 'self' centapp: http: https: data:; style-src 'self' centapp: 'unsafe-inline';"
		},
		"withGlobalTauri": true
	},
	"plugins": {
		"updater": {
			"active": true,
			"dialog": false,
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4MzEwNUM5N0ZFMTQ0RUQKUldUdFJPRi95UVV4V0RvbGR5UzlRUzVDdUdaQWowcU5JQVlXanhWODFobzBVUjdUMFQvS0oyQSsK",
			"endpoints": [
				"https://github.com/glink25/centx/releases/latest/download/latest.json"
			],
			"windows": {
				"installMode": "passive"
			}
		},
		"deep-link": {
			"mobile": [
				{
					"scheme": ["dailycent"],
					"appLink": false
				}
			],
			"desktop": {
				"schemes": ["dailycent"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"android": {
			"minSdkVersion": 24,
			"autoIncrementVersionCode": false
		},
		"linux": {
			"appimage": {
				"bundleMediaFramework": false,
				"files": {}
			},
			"deb": {
				"files": {}
			},
			"rpm": {
				"epoch": 0,
				"files": {},
				"release": "1"
			}
		},
		"macOS": {
			"dmg": {
				"appPosition": {
					"x": 180,
					"y": 170
				},
				"applicationFolderPosition": {
					"x": 480,
					"y": 170
				},
				"windowSize": {
					"height": 400,
					"width": 660
				}
			},
			"files": {},
			"hardenedRuntime": true,
			"minimumSystemVersion": "10.13"
		},
		"windows": {
			"allowDowngrades": true,
			"tsp": false,
			"webviewInstallMode": {
				"silent": true,
				"type": "downloadBootstrapper"
			}
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico",
			"icons/icon.png",
			"icons/ios/*.png"
		]
	}
}
